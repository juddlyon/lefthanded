---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  bodyClass?: string;
  pubDate?: string;
  updatedDate?: string;
  noIndex?: boolean;
  extraSchemas?: Record<string, any>[];
}

const {
  title,
  description = 'LeftHanded.io covers everything left-handed: expert tips, insightful articles, and unique products.',
  ogImage,
  ogType = 'website',
  bodyClass = '',
  pubDate,
  updatedDate,
  noIndex = false,
  extraSchemas = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href) : undefined;

const jsonLd = ogType === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      ...(ogImageURL && { image: ogImageURL }),
      ...(pubDate && { datePublished: pubDate }),
      ...(updatedDate && { dateModified: updatedDate }),
      author: {
        '@type': 'Person',
        name: 'Sammy Southpaw',
        url: `${Astro.site}about/`,
      },
      publisher: {
        '@type': 'Organization',
        name: 'lefthanded.io',
        url: Astro.site,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalURL.href,
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'lefthanded.io',
      url: Astro.site,
      description,
      potentialAction: {
        '@type': 'SearchAction',
        target: `${Astro.site}?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="theme-color" content="#FF1A75">
  {noIndex && <meta name="robots" content="noindex,follow" />}
  <link rel="canonical" href={canonicalURL.href}>
  <link rel="stylesheet" href="/assets/built/screen.css">
  <link rel="stylesheet" href="/ghost-public/cards.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://code.jquery.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400;1,700&family=Mulish:ital,wght@0,400;0,700;0,800;1,400;1,700&display=swap">

  <!-- Favicons -->
  <link rel="icon" href="/content/images/size/w256h256/2022/01/lefthanded-io-icon.png" type="image/png">
  <link rel="apple-touch-icon" href="/content/images/size/w256h256/2022/01/lefthanded-io-icon.png">

  <!-- Open Graph -->
  <meta property="og:site_name" content="lefthanded.io">
  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL.href}>
  <meta property="og:locale" content="en_US">
  {ogImageURL && <meta property="og:image" content={ogImageURL} />}
  {pubDate && <meta property="article:published_time" content={pubDate} />}
  {updatedDate && <meta property="article:modified_time" content={updatedDate} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="lefthanded.io" href="/rss.xml">

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {extraSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <script is:inline>
    if (localStorage.getItem('alto_dark') == 'true') {
      document.documentElement.classList.add('dark-mode');
    }
  </script>
  <style is:global>
    :root {--ghost-accent-color: #FF1A75;}
    .lazyload, .lazyloading { opacity: 1 !important; }
    .post-image, .author-image { position: relative; height: auto; width: 100%; object-fit: cover; }
    .post-media .u-placeholder { overflow: hidden; }
    .post-media .u-placeholder .post-image { position: absolute; top: 0; left: 0; height: 100%; }
    .skip-to-content {
      position: absolute;
      left: -9999px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
    .skip-to-content:focus {
      position: fixed;
      top: 10px;
      left: 10px;
      width: auto;
      height: auto;
      padding: 10px 20px;
      background: var(--ghost-accent-color);
      color: #fff;
      z-index: 9999;
      text-decoration: none;
      font-weight: 700;
      border-radius: 4px;
    }
  </style>
</head>
<body class={bodyClass}>
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <div class="site">
    <header class="site-header container">
      <div class="navbar">
        <div class="navbar-left">
          <div class="burger hidden-lg hidden-xl" aria-label="Open menu" role="button" tabindex="0"></div>
          <a class="logo" href="/">
            <img class="logo-image" src="/content/images/lefthanded-io-logo.svg" alt="lefthanded.io">
          </a>
          <div class="sep hidden-xs hidden-sm hidden-sm"></div>
          <nav class="main-menu hidden-xs hidden-sm hidden-md" aria-label="Main navigation">
            <ul class="nav-list u-plain-list">
              <li class="menu-item menu-item-facts"><a class="menu-item-link" href="/tag/facts/">Facts</a></li>
              <li class="menu-item menu-item-people"><a class="menu-item-link" href="/tag/people/">People</a></li>
              <li class="menu-item menu-item-products"><a class="menu-item-link" href="/tag/products/">Products</a></li>
              <li class="menu-item menu-item-sports"><a class="menu-item-link" href="/tag/sports/">Sports</a></li>
              <li class="menu-item menu-item-music"><a class="menu-item-link" href="/tag/music/">Music</a></li>
              <li class="menu-item menu-item-professions"><a class="menu-item-link" href="/tag/professions/">Professions</a></li>
            </ul>
          </nav>
        </div>
        <div class="navbar-right">
          <div class="toggle-track" role="button" tabindex="0" aria-label="Toggle dark mode">
            <div class="toggle-moon"><i class="icon icon-brightness-2"></i></div>
            <div class="toggle-sun"><i class="icon icon-white-balance-sunny"></i></div>
            <div class="toggle-thumb"></div>
          </div>
        </div>
      </div>
    </header>

    <div class="site-content" id="main-content">
      <slot />
    </div>

    <footer class="site-footer container large">
      <div class="copyright">
        &copy; {new Date().getFullYear()} lefthanded.io
      </div>
      <nav class="footer-nav" aria-label="Footer navigation">
        <ul class="nav-list u-plain-list">
          <li class="menu-item menu-item-about"><a class="menu-item-link" href="/about/">About</a></li>
          <li class="menu-item menu-item-contact"><a class="menu-item-link" href="/contact/">Contact</a></li>
        </ul>
      </nav>
    </footer>
  </div>

  <div class="dimmer"></div>
  <div class="off-canvas" aria-hidden="true" aria-label="Mobile menu">
    <div class="canvas-close" role="button" tabindex="0" aria-label="Close menu">
      <i class="canvas-icon icon icon-window-close"></i>
    </div>
    <div class="mobile-menu"></div>
  </div>

  <script is:inline defer src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script is:inline defer src="/assets/built/main.min.js"></script>
  <script is:inline defer src="/ghost-public/cards.min.js"></script>
</body>
</html>
